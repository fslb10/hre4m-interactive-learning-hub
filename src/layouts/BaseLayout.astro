---
import '../styles/global.css';

type Props = {
  title: string;
  description: string;
  className?: string;
};

const { title, description, className = '' } = Astro.props;
const canonical = Astro.site ? new URL(Astro.url.pathname, Astro.site) : Astro.url;
const rawBase = import.meta.env.BASE_URL;
const base = rawBase.endsWith('/') ? rawBase : `${rawBase}/`;
const ogImage = Astro.site ? new URL(`${base}og.png`, Astro.site) : null;
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width" />
    <meta name="theme-color" content="#18234d" />
    <meta name="description" content={description} />
    <meta name="generator" content={Astro.generator} />
    <link rel="canonical" href={canonical} />
    <meta property="og:type" content="website" />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:url" content={canonical} />
    {ogImage && <meta property="og:image" content={ogImage} />}
    {ogImage && <meta property="og:image:width" content="1731" />}
    {ogImage && <meta property="og:image:height" content="909" />}
    {ogImage && <meta property="og:image:alt" content="HRE4M Unit 2 Gospel Exegesis learning hub" />}
    <meta name="twitter:card" content="summary_large_image" />
    {ogImage && <meta name="twitter:image" content={ogImage} />}
    <title>{title}</title>
  </head>
  <body class={className}>
    <a class="skip-link" href="#main-content">Skip to main content</a>
    <slot />
  </body>
</html>
