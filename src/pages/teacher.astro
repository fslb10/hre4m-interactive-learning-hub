---
import BaseLayout from '../layouts/BaseLayout.astro';
import TeacherToolsPage from '../components/TeacherToolsPage.svelte';
import { gospelLessons } from '../content/lessons';

const rawBase = import.meta.env.BASE_URL;
const base = rawBase.endsWith('/') ? rawBase : `${rawBase}/`;
---

<BaseLayout
  title="Teacher Assignment Builder · HRE4M Learning Hub"
  description="Create a focused, shareable Unit 2 Gospel assignment for HRE4M students."
  className="teacher-builder-page"
>
  <TeacherToolsPage client:load lessons={gospelLessons} {base} />
</BaseLayout>
