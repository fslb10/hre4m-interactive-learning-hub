---
import BaseLayout from '../../layouts/BaseLayout.astro';
import LessonShell from '../../components/LessonShell.svelte';
import { gospelLessons } from '../../content/lessons';

export function getStaticPaths() {
  return gospelLessons.map((lesson) => ({
    params: { gospel: lesson.shortName.toLowerCase() },
    props: { lesson },
  }));
}

const { lesson } = Astro.props;
const rawBase = import.meta.env.BASE_URL;
const base = rawBase.endsWith('/') ? rawBase : `${rawBase}/`;
---

<BaseLayout
  title={`${lesson.title} · HRE4M Learning Hub`}
  description={`An interactive Unit 2 exegesis and Four Senses lesson for the Gospel of ${lesson.shortName}.`}
  className="lesson-page"
>
  <main id="main-content">
    <LessonShell client:load {lesson} homeHref={base} />
  </main>
</BaseLayout>
